# TickTick OAuth credentials (from https://developer.ticktick.com/manage)
TICKTICK_CLIENT_ID=your_client_id_here
TICKTICK_CLIENT_SECRET=your_client_secret_here

# 部署到雲端後，改成你的 Railway/Render URL（含 /auth/callback）
REDIRECT_URI=https://your-app.railway.app/auth/callback

# 雲端平台通常會自動設定 PORT，本機預設 8765
PORT=8765

# Railway Volume 掛載路徑（用於儲存 token.json，防止重啟後遺失）
# Railway 上設定為 /data，本機留空即可
TOKEN_DIR=/data
